# ─── AI Providers ────────────────────────────────────────────────────────────
# Configure the providers you want to use. At least one is required.
# Server will automatically use the highest-priority configured provider.

# 1. Groq (Recommended — Free, Fast, Llama 3.3 70B)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# 2. Google Gemini (Supports Images ✅)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 3. OpenAI (Supports Images ✅)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 4. DeepSeek (Text only ⛔)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
# URL of the Vite frontend (for CORS)
APP_URL=http://localhost:3000

# Port for the AI backend proxy server
AI_SERVER_PORT=3001
